{
  "name": "DemoPipeline",
  "properties": {
    "parameters": {
      "inputPath": { "type": "String", "defaultValue": "demo-source.csv" },
      "outputPath": { "type": "String", "defaultValue": "demo-output.csv" }
    },
    "activities": [
      {
        "name": "CopyAndTransformCSV",
        "type": "Copy",
        "typeProperties": {
          "source": { "type": "DelimitedTextSource" },
          "sink": { "type": "DelimitedTextSink" },
          "translator": {
            "type": "TabularTranslator",
            "mappings": [
              { "source": { "name": "Name", "type": "String" }, "sink": { "name": "NAME_UPPER", "type": "String" }, "expression": "upper(Name)" },
              { "source": { "name": "Age", "type": "Int32" }, "sink": { "name": "Age", "type": "Int32" } }
            ]
          }
        },
        "inputs": [{ "referenceName": "DS_InputCSV", "type": "DatasetReference" }],
        "outputs": [{ "referenceName": "DS_OutputCSV", "type": "DatasetReference" }]
      }
    ]
  }
}
